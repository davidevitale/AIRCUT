rules_version = '2';

// Aircut — Firestore Security Rules
// Generato in Milestone 5 (UGC safety + account management + post ownership).
// Da deployare separatamente: `firebase deploy --only firestore:rules`.

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers =====
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isBarber() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/barbers/$(request.auth.uid));
    }

    // ===== Users: clients =====
    match /clients/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      // M5 §5.2.b — il proprietario può cancellare il proprio doc.
      allow delete: if isOwner(userId);

      // M5 §5.1.c — lista blocchi: solo il proprietario può leggere/scrivere.
      match /blocked/{blockedUid} {
        allow read, write: if isOwner(userId);
      }
    }

    // ===== Users: barbers =====
    match /barbers/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      // M5 §5.2.b — il proprietario può cancellare il proprio doc.
      allow delete: if isOwner(userId);

      // M5 §5.1.c — lista blocchi: solo il proprietario può leggere/scrivere.
      match /blocked/{blockedUid} {
        allow read, write: if isOwner(userId);
      }
    }

    // ===== Posts (M2) =====
    match /posts/{postId} {
      allow read: if isAuthenticated();

      // Solo barbieri possono creare post; il campo authorUid deve coincidere
      // con request.auth.uid (sicurezza ownership invariata da M2).
      allow create: if isBarber()
        && request.resource.data.barberId == request.auth.uid;

      // Update / delete: solo l'autore del post.
      allow update, delete: if isAuthenticated()
        && resource.data.barberId == request.auth.uid;
    }

    // ===== Reports (M5 §5.1.b) =====
    // create-only: qualunque utente autenticato può segnalare contenuti altrui.
    // Read/update/delete bloccati: la review avviene dalla Firebase Console
    // (o futuro pannello admin server-side). SLA review: 24h (impegno operativo).
    match /reports/{reportId} {
      allow create: if isAuthenticated()
        && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // ===== Tags (read-only per app) =====
    match /tags/{tagId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
