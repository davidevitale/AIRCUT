rules_version = '2';

// Aircut — Firebase Storage Security Rules
// Aggiunte post-audit (Step 1). Ownership coerente con `firestore.rules`.
// Deploy separato: `firebase deploy --only storage`.
//
// Principio: regole additive/protette. La validazione media è applicata SOLO a
// create/update (su delete `request.resource` è null, quindi il delete del
// proprietario — usato anche da deleteAccount nello Step 5 — resta funzionante).

service firebase.storage {
  match /b/{bucket}/o {

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // Validazione applicata SOLO a create/update (su delete request.resource è null).
    function isValidMedia() {
      return request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*');
    }

    // --- Profilo / avatar ---
    match /profile/{uid}/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isOwner(uid) && isValidMedia();
      allow delete:         if isOwner(uid);
    }

    // --- Portfolio immagini ---
    match /portfolio/images/{uid}/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isOwner(uid) && isValidMedia();
      allow delete:         if isOwner(uid);
    }

    // --- Portfolio video ---
    match /portfolio/videos/{uid}/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isOwner(uid) && isValidMedia();
      allow delete:         if isOwner(uid);
    }

    // --- Media dei post ---
    // LIMITE NOTO: le Storage Rules non possono leggere Firestore per verificare
    // che request.auth.uid sia davvero il barbiere proprietario di {postId}.
    // Qui vincoliamo la scrittura ad utenti autenticati + validazione media.
    // Per granularità per-post (solo il proprietario può scrivere/eliminare i
    // media di un suo post) la verifica ownership va fatta lato Cloud Function
    // con privilegi admin, oppure usando un path che includa l'uid del
    // proprietario (es. posts/{ownerUid}/{postId}/**) così da poter applicare
    // isOwner(ownerUid).
    match /posts/{postId}/{allPaths=**} {
      allow read:           if isAuthed();
      allow create, update: if isAuthed() && isValidMedia();
      allow delete:         if isAuthed();
    }

    // --- Default deny per qualsiasi altro path ---
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
